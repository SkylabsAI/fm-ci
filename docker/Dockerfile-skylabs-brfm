RUN make -C fmdeps/cpp2v ast-prepare

## BEGIN: [dune build .] issue
#
#  For some reason, after doing all of the above [dune build .] has 4 failing targets. However, if I
#  re-run [dune build .] then everything succeeds. My best guess is that some dune dependency is broken
#  but I can't easily debug it. For now we end this initial invocation with [|| true] and require
#  that a reinvocation is successful.
RUN dune build . || true
RUN dune build .
## END: [dune build .] issue

RUN dune install

WORKDIR /home/coq
# v-- Remove the source code now that we've successfully run [dune install]
RUN rm -rf fm-workspace