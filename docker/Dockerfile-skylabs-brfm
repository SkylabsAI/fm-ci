ARG BRFM_BASE_IMAGE
FROM $BRFM_BASE_IMAGE

# Copy the fully-cloned [fm-workspace] into [/home/coq/fm-workspace]
ADD --chown=coq:coq fm-workspace /home/coq/fm-workspace

# /-- System dependencies required by [fm-workspace/setup-fmdeps.sh] but not installed
# |   within the [Dockerfile-fm-ci] image.
# v
RUN sudo apt-get install -y -q \
         libcairo2-dev \
         libexpat1-dev \
         libgtk-3-dev \
         libgtksourceview-3.0-dev

WORKDIR /home/coq/fm-workspace

